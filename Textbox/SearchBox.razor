    //         // Update bound value
    //         await SearchQueryChanged.InvokeAsync(newValue);
    //     }
    //     catch (TaskCanceledException) { }
    // }
    private string lastSearch;
    private async Task OnInput(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? string.Empty;

        _cts?.Cancel();
        _cts = new CancellationTokenSource();

        try
        {
            await Task.Delay(Debounce, _cts.Token);

            // 🔴 Case 1: Below minimum length
            if (newValue.Length < 3)
            {
                // Reset only once (avoid repeated calls)
                if (!string.IsNullOrEmpty(lastSearch))
                {
                    lastSearch = string.Empty;
                    await SearchQueryChanged.InvokeAsync(string.Empty);
                }
                return;
            }

            // 🟡 Case 2: Avoid duplicate calls
            if (newValue == lastSearch)
                return;

            lastSearch = newValue;

            // 🟢 Case 3: Valid search
            await SearchQueryChanged.InvokeAsync(newValue);
        }
        catch (TaskCanceledException)
        {
            // ignore
        }
    }
    protected override void OnInitialized()
    {
        debounceTimer = new Timer();
        debounceTimer.Interval = Debounce;
        debounceTimer.AutoReset = false;
        debounceTimer.Elapsed += Search;
    }

    async void Search(Object source, ElapsedEventArgs e)
    {
        await InvokeAsync(() => SearchQueryChanged.InvokeAsync(SearchQuery));
    }

    public void Dispose()
    { debounceTimer.Dispose(); }
}
