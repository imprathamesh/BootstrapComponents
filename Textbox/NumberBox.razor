@using System.Globalization
@typeparam TValue
@inherits InputBase<TValue>

@if (LabelPosition == LabelPosition.Floating)
{
    <div class="form-floating">
        <input @attributes="AdditionalAttributes"
               id="@InputId"
               type="number"
               class="@InputCssClass"
               value="@CurrentValueAsString"
               @oninput="HandleInput" @onchange="HandleChange" @onclick="HandleClick"
               min="@Min"
               max="@Max"
               step="@Step"
               placeholder="@PlaceholderText"
               disabled="@Disabled"
               readonly="@ReadOnly" />

        <label for="@InputId">@Label</label>
    </div>
}
else if (LabelPosition == LabelPosition.Top)
{
    <div>
        @if (!string.IsNullOrWhiteSpace(Label))
        {
            <label for="@InputId" class="form-label">
                @Label
            </label>
        }

        <input @attributes="AdditionalAttributes"
               id="@InputId"
               type="number"
               class="@InputCssClass"
               value="@CurrentValueAsString"
               @oninput="HandleInput" @onchange="HandleChange" @onclick="HandleClick"
               min="@Min"
               max="@Max"
               step="@Step"
               placeholder="@PlaceholderText"
               disabled="@Disabled"
               readonly="@ReadOnly" />
    </div>
}
else if (LabelPosition == LabelPosition.Left)
{
    <div class="row align-items-center">
        <div class="col-auto">
            <label for="@InputId" class="col-form-label">
                @Label
            </label>
        </div>

        <div class="col">
            <input @attributes="AdditionalAttributes"
                   id="@InputId"
                   type="number"
                   class="@InputCssClass"
                   value="@CurrentValueAsString"
                   @oninput="HandleInput" @onchange="HandleChange" @onclick="HandleClick"
                   min="@Min"
                   max="@Max"
                   step="@Step"
                   placeholder="@PlaceholderText"
                   disabled="@Disabled"
                   readonly="@ReadOnly" />
        </div>
    </div>
}
else
{
    <input @attributes="AdditionalAttributes"
           id="@InputId"
           type="number"
           class="@InputCssClass"
           value="@CurrentValueAsString"
           @oninput="HandleInput" @onchange="HandleChange" @onclick="HandleClick"
           min="@Min"
           max="@Max"
           step="@Step"
           placeholder="@PlaceholderText"
           disabled="@Disabled"
           readonly="@ReadOnly" />
}

@if (ShowValidationMessage)
{
    <ValidationMessage For="ValueExpression" />
}

@code
{
    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public LabelPosition LabelPosition { get; set; }
        = LabelPosition.Floating;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public bool ShowValidationMessage { get; set; } = true;

    [Parameter]
    public decimal? Min { get; set; }

    [Parameter]
    public decimal? Max { get; set; }

    [Parameter]
    public decimal? Step { get; set; }

    [Parameter]
    public string CssClass { get; set; }  

    [Parameter]
    public EventCallback<ChangeEventArgs> OnInput { get; set; }

    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

 

    protected string InputId =>
        $"num_{FieldIdentifier.FieldName}";

    protected string PlaceholderText =>
        Placeholder ?? Label ?? string.Empty;

    protected string InputCssClass =>
        $"form-control {CssClass} {EditContext?.FieldCssClass(FieldIdentifier)}";

    private async Task HandleInput(ChangeEventArgs e)
    {
        CurrentValueAsString = e.Value?.ToString();

        if (OnInput.HasDelegate)
        {
            await OnInput.InvokeAsync(e);
        }
    }
    private async Task HandleClick(MouseEventArgs e)
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync(e);
        }
    }
    private async Task HandleChange(ChangeEventArgs e)
    {
        CurrentValueAsString = e.Value?.ToString();

        if (OnChange.HasDelegate)
        {
            await OnChange.InvokeAsync(e);
        }
    }

    protected override bool TryParseValueFromString(
        string? value,
        out TValue result,
        out string? validationErrorMessage)
    {
        var targetType =
            Nullable.GetUnderlyingType(typeof(TValue))
            ?? typeof(TValue);

        try
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                result = default!;
                validationErrorMessage = null;
                return true;
            }

            object parsedValue;

            if (targetType == typeof(int))
            {
                parsedValue = int.Parse(value, CultureInfo.InvariantCulture);
            }
            else if (targetType == typeof(long))
            {
                parsedValue = long.Parse(value, CultureInfo.InvariantCulture);
            }
            else if (targetType == typeof(short))
            {
                parsedValue = short.Parse(value, CultureInfo.InvariantCulture);
            }
            else if (targetType == typeof(decimal))
            {
                parsedValue = decimal.Parse(value, CultureInfo.InvariantCulture);
            }
            else if (targetType == typeof(double))
            {
                parsedValue = double.Parse(value, CultureInfo.InvariantCulture);
            }
            else if (targetType == typeof(float))
            {
                parsedValue = float.Parse(value, CultureInfo.InvariantCulture);
            }
            else
            {
                throw new InvalidOperationException(
                    $"NumberBox does not support {targetType.Name}");
            }

            result = (TValue)parsedValue;
            validationErrorMessage = null;
            return true;
        }
        catch
        {
            result = default!;

            validationErrorMessage =
                $"The {FieldIdentifier.FieldName} field is not valid.";

            return false;
        }
    }
}