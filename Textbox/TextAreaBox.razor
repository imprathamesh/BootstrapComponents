@inherits InputBase<string?>

@if (LabelPosition == LabelPosition.Floating)
{
    <div class="form-floating @CssClass">
        <textarea @attributes="AdditionalAttributes" id="@InputId" class="@InputCssClass" placeholder="@PlaceholderText" rows="@Rows" @oninput="HandleInput" @onchange="HandleChange" @onclick="HandleClick">@CurrentValue</textarea>
        <label for="@InputId">@Label</label>
    </div>
}
else if (LabelPosition == LabelPosition.Top)
{
    <div class="@CssClass">
        @if (!string.IsNullOrWhiteSpace(Label))
        {
            <label for="@InputId" class="form-label">
                @Label
            </label>
        }
        <textarea @attributes="AdditionalAttributes" id="@InputId" class="@InputCssClass" placeholder="@PlaceholderText" rows="@Rows" @oninput="HandleInput" @onchange="HandleChange" @onclick="HandleClick">@CurrentValue</textarea>
    </div>
}
else if (LabelPosition == LabelPosition.Left)
{
    <div class="row align-items-start @CssClass">
        <div class="col-auto">
            <label for="@InputId" class="col-form-label">
                @Label
            </label>
        </div>
        <div class="col">
            <textarea @attributes="AdditionalAttributes" id="@InputId" class="@InputCssClass" placeholder="@PlaceholderText" rows="@Rows" @oninput="HandleInput" @onchange="HandleChange" @onclick="HandleClick">@CurrentValue</textarea>
        </div>
    </div>
}
else
{
    <textarea @attributes="AdditionalAttributes" id="@InputId" class="@InputCssClass" placeholder="@PlaceholderText" rows="@Rows" @oninput="HandleInput" @onchange="HandleChange" @onclick="HandleClick">@CurrentValue</textarea>
}

@if (ShowValidationMessage)
{
    <ValidationMessage For="ValueExpression" />
}

@code
{
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public LabelPosition LabelPosition { get; set; } = LabelPosition.Floating;
    [Parameter] public bool ShowValidationMessage { get; set; } = true;
    [Parameter] public int Rows { get; set; } = 4;
    [Parameter] public string CssClass { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> OnInput { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> OnChange { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }

    protected string InputId => $"txtarea_{FieldIdentifier.FieldName}";
    protected string PlaceholderText => Placeholder ?? Label ?? string.Empty;
    protected string InputCssClass => $"form-control {CssClass} {EditContext?.FieldCssClass(FieldIdentifier)}";

    private async Task HandleInput(ChangeEventArgs e)
    {
        CurrentValue = e.Value?.ToString();

        if (OnInput.HasDelegate)
        {
            await OnInput.InvokeAsync(e);
        }
    }
    private async Task HandleClick(MouseEventArgs e)
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync(e);
        }
    }
    private async Task HandleChange(ChangeEventArgs e)
    {
        CurrentValue = e.Value?.ToString();

        if (OnInput.HasDelegate)
        {
            await OnInput.InvokeAsync(e);
        }
    }

    protected override bool TryParseValueFromString(string? value, out string? result, out string? validationErrorMessage)
    {
        result = value;
        validationErrorMessage = null;
        return true;
    }
}